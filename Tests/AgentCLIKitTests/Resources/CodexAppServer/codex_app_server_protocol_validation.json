{
  "codexCLI": {
    "version": "codex-cli 0.137.0-alpha.4",
    "schemaCommands": [
      "codex app-server generate-json-schema --out <redacted:path>",
      "codex app-server generate-ts --out <redacted:path>"
    ],
    "generatedSchema": {
      "jsonBundleFiles": [
        "codex_app_server_protocol.schemas.json",
        "codex_app_server_protocol.v2.schemas.json"
      ],
      "jsonBundleByteCounts": {
        "codex_app_server_protocol.schemas.json": 509729,
        "codex_app_server_protocol.v2.schemas.json": 424682
      }
    }
  },
  "documentation": {
    "source": "https://developers.openai.com/codex/app-server",
    "transport": {
      "default": "stdio://",
      "stdioFraming": "newline-delimited JSON",
      "websocket": "experimental and unsupported",
      "unixSocket": "websocket over a Unix socket"
    },
    "jsonRPC": {
      "wireOmitsJsonrpcHeader": true,
      "requestsUseIdMethodParams": true,
      "responsesUseIdAndResultOrError": true,
      "notificationsOmitId": true
    },
    "initialization": {
      "requiresInitializeBeforeOtherRequests": true,
      "requiresInitializedNotification": true,
      "experimentalApiCapability": "capabilities.experimentalApi"
    }
  },
  "schema": {
    "clientRequestsValidatedForV1": [
      "initialize",
      "thread/start",
      "thread/resume",
      "thread/archive",
      "thread/read",
      "turn/start",
      "turn/steer",
      "turn/interrupt",
      "thread/compact/start",
      "model/list",
      "permissionProfile/list"
    ],
    "clientRequestsObservedInGeneratedSchema": [
      "config/read",
      "config/value/write",
      "config/batchWrite",
      "mcpServerStatus/list",
      "mcpServer/oauth/login",
      "mcpServer/resource/read",
      "mcpServer/tool/call",
      "review/start"
    ],
    "serverRequests": [
      "item/commandExecution/requestApproval",
      "item/fileChange/requestApproval",
      "item/permissions/requestApproval",
      "mcpServer/elicitation/request",
      "item/tool/requestUserInput",
      "item/tool/call",
      "account/chatgptAuthTokens/refresh",
      "attestation/generate",
      "applyPatchApproval",
      "execCommandApproval"
    ],
    "serverNotificationsRelevantToV1": [
      "thread/started",
      "thread/name/updated",
      "thread/status/changed",
      "thread/settings/updated",
      "turn/started",
      "turn/completed",
      "turn/diff/updated",
      "turn/plan/updated",
      "thread/tokenUsage/updated",
      "thread/compacted",
      "item/started",
      "item/completed",
      "item/agentMessage/delta",
      "fileChange/patch/updated",
      "model/rerouted",
      "model/verification",
      "serverRequest/resolved"
    ],
    "threadMetadata": {
      "threadObject": {
        "id": "opaque string",
        "name": "nullable string"
      },
      "bootstrapSources": [
        "thread/start result.thread.name",
        "thread/resume result.thread.name",
        "thread/started params.thread.name"
      ],
      "nameUpdateNotification": {
        "method": "thread/name/updated",
        "fields": {
          "threadId": "string",
          "threadName": "optional string"
        }
      }
    },
    "approvalResponses": {
      "commandExecution": {
        "method": "item/commandExecution/requestApproval",
        "responseShape": {
          "decision": "CommandExecutionApprovalDecision"
        },
        "decisions": [
          "accept",
          "acceptForSession",
          "acceptWithExecpolicyAmendment",
          "applyNetworkPolicyAmendment",
          "decline",
          "cancel"
        ]
      },
      "fileChange": {
        "method": "item/fileChange/requestApproval",
        "responseShape": {
          "decision": "FileChangeApprovalDecision"
        },
        "decisions": [
          "accept",
          "acceptForSession",
          "decline",
          "cancel"
        ]
      },
      "permissionProfile": {
        "method": "item/permissions/requestApproval",
        "responseShape": {
          "permissions": "GrantedPermissionProfile",
          "scope": "turn | session",
          "strictAutoReview": "optional boolean"
        },
        "denialSemantics": {
          "schemaHasExplicitDenialDecision": false,
          "liveProbeStatus": "notTriggeredByPromptedRequest",
          "implementationGuidance": "Do not invent a decline enum. Treat host denial as unresolved until adapter work validates a safe fallback, such as JSON-RPC error or turn interrupt, against an actual server request."
        }
      },
      "mcpElicitation": {
        "method": "mcpServer/elicitation/request",
        "responseShape": {
          "action": "accept | decline | cancel",
          "content": "nullable JSON value",
          "_meta": "nullable JSON value"
        }
      },
      "toolRequestUserInput": {
        "method": "item/tool/requestUserInput",
        "responseShape": {
          "answers": "dictionary keyed by question id"
        },
        "classification": "answer-oriented prompt, not an approval prompt"
      },
      "dynamicToolCall": {
        "method": "item/tool/call",
        "responseShape": {
          "contentItems": "array",
          "success": "boolean"
        },
        "v1Guidance": "Return an unsupported-tool response unless adapter live validation proves host-defined tool handling is required for normal built-in operation."
      }
    }
  },
  "liveValidation": {
